generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
}

model Candidate {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  party             String
  partyShort        String
  color             String
  announcedDate     String
  status            String
  description       String
  source            String
  photo             String?
  mandates          String[]
  previousElections PreviousElection[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PreviousElection {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  year       Int
  round      String
  score      String
  candidate  Candidate @relation(fields: [candidateId], references: [id])
  candidateId String @db.ObjectId
}

model Party {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  shortName   String   @unique
  name        String
  color       String
  logo        String?
  founded     String
  position    String
  description String
  history     String
  leader      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Article {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  source    String
  date      String
  url       String
  summary   String
  category  String
  mentions  String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgendaHint {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  source        String
  candidateId   String
  candidateName String
  label         String
  description   String
  date          String
  type          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Poll {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  source      String
  date        String
  sampleSize  Int
  url         String
  candidates  PollCandidate[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PollCandidate {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  partyShort String
  score      Float
  color      String
  poll       Poll    @relation(fields: [pollId], references: [id])
  pollId     String  @db.ObjectId
}

model QuizQuestion {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  question  String
  option0   String
  option1   String
  option2   String
  option3   String
  answer    Int
  createdAt DateTime @default(now())
}

model TimelineEvent {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  date         String
  label        String
  description  String
  type         String
  candidateId  String?
  highlight    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
